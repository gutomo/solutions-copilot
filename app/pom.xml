<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <!-- Spring AI 1.0.x is built against the Spring Boot 3.4 line. -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.4.5</version>
        <relativePath/>
    </parent>

    <!-- TODO: rename groupId/artifactId to your own reverse-domain before publishing. -->
    <groupId>com.example.copilot</groupId>
    <artifactId>solutions-copilot</artifactId>
    <version>0.1.0</version>
    <name>solutions-copilot</name>
    <description>Agentic enterprise solutions copilot (Phase 0 baseline)</description>

    <properties>
        <java.version>21</java.version>
        <spring-ai.version>1.0.8</spring-ai.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.ai</groupId>
                <artifactId>spring-ai-bom</artifactId>
                <version>${spring-ai.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- Bedrock Converse: unified chat + tool calling + streaming.
             Credentials are resolved by the AWS default provider chain
             (i.e. the ECS task role at runtime) - no keys in config. -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-bedrock-converse</artifactId>
        </dependency>

        <!-- Phase 1 RAG: Amazon Titan Text Embeddings v2 via Bedrock. The Converse
             starter handles chat; this starter brings in the InvokeModel-based
             Bedrock autoconfig (Titan + Cohere embeddings). spring-ai-bedrock
             alone has the classes but not the autoconfig, so the
             spring.ai.model.embedding=bedrock-titan selector would have no
             auto-config to activate and no EmbeddingModel bean would be wired. -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-bedrock</artifactId>
        </dependency>

        <!-- Phase 1 RAG: pgvector-backed VectorStore. Auto-wires when a DataSource
             and an EmbeddingModel are present on the classpath. -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-vector-store-pgvector</artifactId>
        </dependency>

        <!-- Phase 1 RAG: QuestionAnswerAdvisor (built-in retrieval advisor). In
             Spring AI 1.0.x this moved out of the chat-client core into its own
             module. -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-advisors-vector-store</artifactId>
        </dependency>

        <!-- Phase 2: .docx rendering for the proposal-generator tool. Build-only;
             no new infra. Brings xmlbeans, commons-compress, commons-collections4,
             log4j-api, SparseBitSet transitively (~10 MB). -->
        <dependency>
            <groupId>org.apache.poi</groupId>
            <artifactId>poi-ooxml</artifactId>
            <version>5.3.0</version>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-jdbc</artifactId>
        </dependency>

        <!-- Phase 4 slice 2: OpenTelemetry tracing. Bridge converts the
             existing ObservationRegistry's events (Boot HTTP + Spring AI
             chat client / chat model / vector store / tool calls) into
             OTel spans. OTLP exporter ships them to a collector via HTTP.
             Both BOM-managed by Spring Boot 3.4 (no explicit versions).
             Inert by default: management.tracing.sampling.probability=0
             yields non-recording spans only, so the exporter is never
             invoked, the collector is never contacted, requests answer
             normally. -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-tracing-bridge-otel</artifactId>
        </dependency>
        <dependency>
            <groupId>io.opentelemetry</groupId>
            <artifactId>opentelemetry-exporter-otlp</artifactId>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
        </dependency>

        <!-- Phase 3 slice 1: eval harness (test scope; zero production impact).
             spring-boot-starter-test brings JUnit Jupiter + Spring Test.
             Testcontainers spins up a dedicated pgvector for the eval so the
             dev DB is never touched. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>postgresql</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <!-- Default: exclude @Tag("eval") and @Tag("gate") so `mvn test`
                 never runs either the live eval (needs Bedrock + DB) or the
                 live gate (needs target/eval-report.json on disk). The plain
                 EvalGateFixtureTest has no tag and so DOES run in default; it
                 covers the gate's logic against committed fixtures with no IO
                 dependencies. The `eval` and `gate` profiles below override
                 the exclusion to opt back in. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <excludedGroups>eval,gate</excludedGroups>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- `mvn test -Peval` runs ONLY @Tag("eval") tests.
             combine.self="override" wipes the parent <excludedGroups>eval</>
             so the eval tag is not both included and excluded (which JUnit
             resolves as excluded, running zero tests). -->
        <profile>
            <id>eval</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <groups>eval</groups>
                            <excludedGroups combine.self="override"></excludedGroups>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <!-- `mvn test -Pgate` runs ONLY @Tag("gate") tests (EvalGateTest).
             Runs AFTER `mvn test -Peval` has produced target/eval-report.json;
             reads that report + src/test/resources/eval-thresholds.yml and
             fails the build on any HARD threshold breach. -->
        <profile>
            <id>gate</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-surefire-plugin</artifactId>
                        <configuration>
                            <groups>gate</groups>
                            <excludedGroups combine.self="override"></excludedGroups>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
